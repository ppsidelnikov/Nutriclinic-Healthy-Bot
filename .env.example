# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# YandexGPT
YANDEX_GPT_TOKEN=your_yandex_iam_or_api_token
YANDEX_CLOUD_FOLDER_ID=your_folder_id
YANDEX_GPT_PATH=yandexgpt/latest

# ProxyAPI (OpenAI-compatible vision)
PROXY_API_TEST_KEY=your_proxyapi_key

# FatSecret
FATSECRET_CLIENT_ID=your_fatsecret_client_id
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nutriclinic
DB_USER=nutriclinic
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
# При запуске через docker-compose S3_ENDPOINT переопределяется на http://minio:9000
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nutriclinic
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
